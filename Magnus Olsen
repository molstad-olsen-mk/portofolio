  const mChannel   = document.getElementById('modal-channel');
  const mDesc      = document.getElementById('modal-desc');
  const mLink      = document.getElementById('modal-link');
  const mClose     = document.getElementById('modal-close');

  function openModal(idx) {
    const w = works[idx];
    mBar.className    = 'modal-top-bar ' + w.type;
    mBadge.className  = 'work-badge ' + w.type;
    mTypeLabel.textContent = w.typeLabel;
    mTitle.textContent   = w.title;
    mChannel.textContent = w.channel + ' · ' + w.date;
    mDesc.textContent    = w.desc;
    mLink.href           = w.link;
    mLink.textContent    = w.linkLabel;
    backdrop.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    backdrop.classList.remove('open');
    document.body.style.overflow = '';
  }

  workCells.forEach(cell => {
    cell.addEventListener('click', () => openModal(+cell.dataset.index));
  });
  mClose.addEventListener('click', closeModal);
  backdrop.addEventListener('click', e => { if (e.target === backdrop) closeModal(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
</script>

</body>
</html>
