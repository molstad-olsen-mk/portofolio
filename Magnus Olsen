    .work-badge.artikkel { background: rgba(200,57,26,0.1); color: var(--red); }
    .work-badge.artikkel .dot { background: var(--red); }
    .work-badge.tv       { background: rgba(58,110,168,0.1); color: var(--tv); }
    .work-badge.tv .dot  { background: var(--tv); }
    .work-badge.radio    { background: rgba(124,92,191,0.1); color: var(--radio); }
