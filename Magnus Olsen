      color: var(--ink);
      transition: background 0.15s;
    }
    .contact-row:hover { background: rgba(15,14,13,0.03); }
    .contact-row-label {
      font-family: var(--mono);
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted);
    }
    .contact-row-value {
      font-family: var(--mono);
      font-size: 0.75rem;
      letter-spacing: 0.05em;
      color: var(--ink);
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .contact-row-value .arr { color: var(--red); }

    /* ─── FOOTER ─────────────────────────────────────────────────────── */
    footer {
      border-top: 2px solid var(--ink);
      padding: 1.5rem 2rem;
    }
    .footer-inner {
      max-width: var(--max);
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      flex-wrap: wrap;
    }
    .footer-inner span {
      font-family: var(--mono);
      font-size: 0.65rem;
      letter-spacing: 0.08em;
      color: var(--muted);
    }

    /* ─── MODAL ──────────────────────────────────────────────────────── */
    .modal-backdrop {
      position: fixed;
      inset: 0;
      background: rgba(15,14,13,0.65);
      z-index: 500;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.2s;
    }
    .modal-backdrop.open { opacity: 1; pointer-events: all; }
    .modal {
      background: var(--cream);
      max-width: 560px;
      width: 100%;
      transform: translateY(10px);
      transition: transform 0.2s;
    }
    .modal-backdrop.open .modal { transform: translateY(0); }
    .modal-top-bar {
      height: 4px;
    }
    .modal-top-bar.artikkel { background: var(--red); }
    .modal-top-bar.tv       { background: var(--tv); }
    .modal-top-bar.radio    { background: var(--radio); }
    .modal-body-wrap { padding: 2rem; }
    .modal-meta { margin-bottom: 1rem; }
    .modal-title {
      font-family: var(--serif);
      font-size: 1.5rem;
      font-weight: 700;
      line-height: 1.2;
      margin-bottom: 0.5rem;
    }
    .modal-channel {
      font-family: var(--mono);
      font-size: 0.65rem;
      letter-spacing: 0.08em;
      color: var(--muted);
    }
    .modal-desc {
      font-size: 0.92rem;
      color: var(--muted);
      line-height: 1.7;
      margin-bottom: 1.5rem;
    }
    .modal-footer {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.75rem;
    }
    .modal-link {
      font-family: var(--mono);
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--cream);
      background: var(--red);
      text-decoration: none;
      padding: 0.6rem 1.25rem;
      transition: opacity 0.15s;
    }
    .modal-link:hover { opacity: 0.85; }
    .modal-close {
      font-family: var(--mono);
      font-size: 0.67rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted);
      background: none;
      border: 1px solid var(--rule);
      cursor: pointer;
      padding: 0.6rem 1.1rem;
      transition: all 0.15s;
    }
    .modal-close:hover { border-color: var(--ink); color: var(--ink); }

    /* ─── RESPONSIVE ─────────────────────────────────────────────────── */
    @media (max-width: 860px) {
      .hero-inner { grid-template-columns: 1fr; }
      .hero-divider { display: none; }
      .hero-left  { padding: 2.5rem 1.5rem 2rem; }
      .hero-right { padding: 0 1.5rem 2.5rem; }
      .about-grid { grid-template-columns: 1fr; gap: 2rem; }
      .about-left { flex-direction: row; gap: 1.5rem; align-items: flex-end; }
      .portrait-wrap { max-width: 160px; }
      .contact-wrap { grid-template-columns: 1fr; gap: 2.5rem; }
      .works-grid { grid-template-columns: repeat(2, 1fr); }
      .work-cell:nth-child(3n) { border-right: 1px solid var(--rule); }
      .work-cell:nth-child(2n) { border-right: none; }
