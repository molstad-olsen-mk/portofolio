    .work-cell:hover .work-arrow { opacity: 1; transform: translateX(3px); }

    /* ─── OM MEG ─────────────────────────────────────────────────────── */
    #om-meg {
      border-bottom: 1px solid var(--rule);
    }
    .about-wrap {
      max-width: var(--max);
      margin: 0 auto;
      padding: 0 2rem 3rem;
    }
    .about-grid {
